# Python
__pycache__/
*.py[cod]
*.egg-info/
build/
dist/
.venv/
venv/

# Tooling
.pytest_cache/
.ipynb_checkpoints/

# Artifacts: CSV logs are committed. Model checkpoints are not, EXCEPT the two
# from the main run that experiments/fourier.py needs to reproduce the
# embedding-spectrum figure (and that test_checkpoints.py loads) without
# retraining -- ~0.9 MB each, worth it for clone-and-reproduce.
runs/*.pt
!runs/p97_frac0.30_wd1_seed0.pt
!runs/p97_frac0.30_wd1_seed0_memorize.pt
# lr-sensitivity sweep commits only its CSV trajectories, not checkpoints.
runs_lr/*.pt

# OS
.DS_Store

# Throwaway training side-artifacts from the progress-measure run (the
# committed output is runs/progress_*.csv; the trainer would otherwise reuse
# the main run name and overwrite it).
runs_progress/
